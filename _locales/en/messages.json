  "tour0Key":   { "message": "Harbor · Chart" },
  "tour0Title": { "message": "Welcome to Harbor." },
  "tour0Body":  { "message": "A workspace dock to stop using tabs as storage. Separates <b>anchored places</b> (where you return) from <b>live flow</b> (open tabs). A 30-second tour." },

  "tour1Key":   { "message": "01 · Spaces" },
  "tour1Title": { "message": "Space = work context" },
  "tour1Body":  { "message": "<b>Folders</b> directly under your bookmark bar become spaces. Create with \"+\". Switch with <b>1–9</b> keys or horizontal swipe." },

  "tour2Key":   { "message": "02 · PINS" },
  "tour2Title": { "message": "Always-visible favorites" },
  "tour2Body":  { "message": "Bookmarks placed directly on the bar (not in a folder) appear here regardless of space. Drag a tab here to pin." },

  "tour3Key":   { "message": "03 · Anchored" },
  "tour3Title": { "message": "Return points for this space" },
  "tour3Body":  { "message": "Fix pages you return to as <b>anchors</b>. \"Current tab\" adds today's page; \"Open all\" reopens them together. Lit tiles mean the tab is currently open." },

  "tour4Key":   { "message": "04 · Live flow" },
  "tour4Title": { "message": "Currently open tabs" },
  "tour4Body":  { "message": "Your tabs listed vertically. <b>⚓</b> promotes a tab to an anchor in this space. \"Tidy\" closes tabs not saved anywhere." },

  "tour5Key":   { "message": "Chart complete" },
  "tour5Title": { "message": "Now set sail." },
  "tour5Body": {
    "message": "<b>$MODIFIER$+Shift+K</b> opens/closes the panel anytime. This tour is always available from the <b>?</b> button.",
    "placeholders": { "modifier": { "content": "$1" } }
  }
