  "tour2Key":   { "message": "02 · PINS" },
  "tour2Title": { "message": "どこでも出る定番" },
  "tour2Body":  { "message": "バーに裸で置いたブックマークは、スペースを問わず常にこの列に並びます。タブをここへドラッグすればピン留め。" },

  "tour3Key":   { "message": "03 · 係留 / ANCHORED" },
  "tour3Title": { "message": "このスペースの戻り先" },
  "tour3Body":  { "message": "よく戻るページを<b>錨</b>として固定します。「現在のタブ」で今のページを追加、「すべて開く」でまとめて復帰。点灯しているタイルは、いまそのタブが開いている印です。" },

  "tour4Key":   { "message": "04 · 流れ / LIVE" },
  "tour4Title": { "message": "いま開いているタブ" },
  "tour4Body":  { "message": "現在のタブを縦に一覧。<b>⚓</b> でこのスペースの錨へ格上げ、「片付け」でどこにも保存していないタブだけを閉じられます。" },

  "tour5Key":   { "message": "海図 完成" },
