{
  "manifest_version": 3,
  "name": "Harbor",
  "version": "1.2.0",
  "description": "__MSG_extDescription__",
  "default_locale": "ja",
  "minimum_chrome_version": "114",
  "permissions": ["sidePanel", "tabs", "storage", "favicon", "tabGroups", "bookmarks"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+K", "mac": "Command+Shift+K" },
      "description": "__MSG_commandDescription__"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
